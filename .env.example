# ============================================================
#  CHRONUS — Environment Variables
#  Copie este arquivo para .env e preencha os valores reais.
#  NUNCA suba o .env para o repositório.
# ============================================================

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (Supabase PostgreSQL)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-supabase-host.supabase.co
DB_PORT=5432
DB_SSLMODE=require

# Redis
REDIS_URL=redis://localhost:6379/0

# Email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=CHRONUS <noreply@chronus.app>

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_BUCKET=chronus-media

# Google OAuth (django-allauth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry (produção)
SENTRY_DSN=

# CORS (produção)
CORS_ALLOWED_ORIGINS=https://chronus.app
